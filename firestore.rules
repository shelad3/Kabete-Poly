rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ---------------------------------------------------- //
    // Helper Functions
    // ---------------------------------------------------- //
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'Official';
    }

    function isTeacherOrAbove() {
      return isAuthenticated() && (getUserRole() == 'Teacher' || getUserRole() == 'Official');
    }

    function isLeaderOrAbove() {
      return isAuthenticated() && (getUserRole() == 'Leader' || getUserRole() == 'Teacher' || getUserRole() == 'Official');
    }

    // ---------------------------------------------------- //
    // Users Collection
    // ---------------------------------------------------- //
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isOwner(userId);
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------- //
    // Messages / Forum Collection
    // ---------------------------------------------------- //
    match /messages/{messageId} {
      allow read, create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.senderId == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.senderId == request.auth.uid || isAdmin());
    }

    // ---------------------------------------------------- //
    // Forum Channels
    // ---------------------------------------------------- //
    match /forum_channels/{channelId} {
      allow read: if isAuthenticated();
      allow create: if isLeaderOrAbove();
      allow update: if isTeacherOrAbove();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------- //
    // Grades Collection
    // ---------------------------------------------------- //
    match /grades/{gradeId} {
      allow read: if isAuthenticated();
      allow create, update: if isTeacherOrAbove();
      allow delete: if isTeacherOrAbove();
    }

    // ---------------------------------------------------- //
    // Classes / Cohorts Collection + Timetable subcollection
    // ---------------------------------------------------- //
    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow create, update: if isLeaderOrAbove();
      allow delete: if isAdmin();

      match /timetable/{entryId} {
        allow read: if isAuthenticated();
        allow create, update: if isTeacherOrAbove();
        allow delete: if isTeacherOrAbove();
      }
    }

    // ---------------------------------------------------- //
    // Lessons Collection
    // ---------------------------------------------------- //
    match /lessons/{lessonId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isTeacherOrAbove();
    }

    // ---------------------------------------------------- //
    // Schedules Collection
    // ---------------------------------------------------- //
    match /schedules/{scheduleId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isTeacherOrAbove();
    }

    // ---------------------------------------------------- //
    // Notifications Collection
    // ---------------------------------------------------- //
    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isTeacherOrAbove();
    }
    
    // ---------------------------------------------------- //
    // Auth Codes Collection
    // ---------------------------------------------------- //
    match /auth_codes/{codeId} {
      allow read: if isAuthenticated();
      // Only admins can create new codes or delete them
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isUsed', 'usedBy', 'useCount', 'usedAt']);
    }

    // ---------------------------------------------------- //
    // Help Requests Collection
    // ---------------------------------------------------- //
    match /help_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------- //
    // Error Reports Collection
    // ---------------------------------------------------- //
    match /error_reports/{reportId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------- //
    // Feedback Collection
    // ---------------------------------------------------- //
    match /feedback/{feedbackId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------- //
    // Alerts Collection
    // ---------------------------------------------------- //
    match /alerts/{alertId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------- //
    // Attendance Collection
    // ---------------------------------------------------- //
    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow create: if isTeacherOrAbove();
      allow update, delete: if isTeacherOrAbove();
    }

    // ---------------------------------------------------- //
    // Field Indices (Uniqueness Enforcement)
    // ---------------------------------------------------- //
    match /field_indices/{indexId} {
      // Only system writes from authenticated users (register/profile updates)
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------- //
    // Active QR Sessions (Teacher-controlled QR activation)
    // ---------------------------------------------------- //
    match /active_qr_sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isTeacherOrAbove();
      allow update, delete: if isTeacherOrAbove();
    }

    // ---------------------------------------------------- //
    // Lesson Verifications (Student vote taught/not taught)
    // ---------------------------------------------------- //
    match /lesson_verifications/{verificationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();   // students create vote
      allow update: if isAuthenticated();   // students update their vote
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------- //
    // Reports (Auto-uploaded report cards)
    // ---------------------------------------------------- //
    match /reports/{reportId} {
      allow read: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid || isTeacherOrAbove()
      );
      allow create: if isTeacherOrAbove();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------- //
    // Class Change Requests Collection
    // ---------------------------------------------------- //
    match /class_change_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------- //
    // User Sessions subcollection
    // ---------------------------------------------------- //
    match /users/{userId}/sessions/{sessionId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId);
      allow delete: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    // ---------------------------------------------------- //
    // School Info
    // ---------------------------------------------------- //
    match /school_info/{infoId} {
      allow read: if true;  // public — shown to guests too
      allow write: if isAdmin();
    }

    // ---------------------------------------------------- //
    // Events (Event Gallery)
    // ---------------------------------------------------- //
    match /events/{eventId} {
      allow read: if true;  // public — visible to all including guests
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();

      // Photos subcollection
      match /photos/{photoId} {
        allow read: if true;
        allow create: if isAdmin();
        allow delete: if isAdmin();
      }
    }

    // ---------------------------------------------------- //
    // Houses (Buildings containing cubes)
    // ---------------------------------------------------- //
    match /houses/{houseId} {
      allow read: if isAuthenticated();
      allow write: if isTeacherOrAbove();
    }

    // ---------------------------------------------------- //
    // Cubes (Workstations within houses)
    // ---------------------------------------------------- //
    match /cubes/{cubeId} {
      allow read: if isAuthenticated();
      allow write: if isTeacherOrAbove();
    }

    // ---------------------------------------------------- //
    // Cube Bookings
    // ---------------------------------------------------- //
    match /cube_bookings/{bookingId} {
      allow read: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid || isTeacherOrAbove()
      );
      allow create: if isAuthenticated() &&
        request.resource.data.studentId == request.auth.uid;
      allow update: if isTeacherOrAbove() || (
        request.resource.data.studentId == request.auth.uid &&
        request.resource.data.status == 'cancelled'
      );
      allow delete: if false;
    }

    // ---------------------------------------------------- //
    // Quizzes Collection
    // ---------------------------------------------------- //
    match /quizzes/{quizId} {
      allow read: if isAuthenticated();
      allow create: if isTeacherOrAbove();
      allow update: if isTeacherOrAbove();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------- //
    // Questions Collection (top-level, linked by quizId)
    // ---------------------------------------------------- //
    match /questions/{questionId} {
      allow read: if isAuthenticated();
      allow create: if isTeacherOrAbove();
      allow update: if isTeacherOrAbove();
      allow delete: if isTeacherOrAbove();
    }

    // ---------------------------------------------------- //
    // Quiz Submissions Collection
    // ---------------------------------------------------- //
    match /quiz_submissions/{submissionId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isTeacherOrAbove()
      );
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // ---------------------------------------------------- //
    // Lesson Templates Collection
    // ---------------------------------------------------- //
    match /lesson_templates/{templateId} {
      allow read: if isAuthenticated();
      allow create: if isTeacherOrAbove();
      allow update: if isTeacherOrAbove();
      allow delete: if isTeacherOrAbove();
    }

    // ---------------------------------------------------- //
    // Schedule Templates Collection
    // ---------------------------------------------------- //
    match /schedule_templates/{templateId} {
      allow read: if isAuthenticated();
      allow create: if isTeacherOrAbove();
      allow update: if isTeacherOrAbove();
      allow delete: if isTeacherOrAbove();
    }

    // ---------------------------------------------------- //
    // Default: deny everything else
    // ---------------------------------------------------- //
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
