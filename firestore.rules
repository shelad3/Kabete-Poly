rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ---------------------------------------------------- //
    // Helper Functions
    // ---------------------------------------------------- //
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'Official';
    }

    function isTeacherOrAbove() {
      return isAuthenticated() && (getUserRole() == 'Teacher' || getUserRole() == 'Official');
    }

    function isLeaderOrAbove() {
      return isAuthenticated() && (getUserRole() == 'Leader' || getUserRole() == 'Teacher' || getUserRole() == 'Official');
    }

    // ---------------------------------------------------- //
    // Users Collection
    // ---------------------------------------------------- //
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isOwner(userId);
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------- //
    // Messages / Forum Collection
    // ---------------------------------------------------- //
    match /messages/{messageId} {
      allow read, create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.senderId == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.senderId == request.auth.uid || isAdmin());
    }

    // ---------------------------------------------------- //
    // Forum Channels
    // ---------------------------------------------------- //
    match /forum_channels/{channelId} {
      allow read: if isAuthenticated();
      allow create: if isLeaderOrAbove();
      allow update: if isTeacherOrAbove();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------- //
    // Classes / Cohorts Collection + Timetable subcollection
    // ---------------------------------------------------- //
    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow create, update: if isLeaderOrAbove();
      allow delete: if isAdmin();

      match /timetable/{entryId} {
        allow read: if isAuthenticated();
        allow create, update: if isTeacherOrAbove();
        allow delete: if isTeacherOrAbove();
      }
    }

    // ---------------------------------------------------- //
    // Lessons Collection
    // ---------------------------------------------------- //
    match /lessons/{lessonId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isTeacherOrAbove();
    }

    // ---------------------------------------------------- //
    // Schedules Collection
    // ---------------------------------------------------- //
    match /schedules/{scheduleId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isTeacherOrAbove();
    }

    // ---------------------------------------------------- //
    // Notifications Collection
    // ---------------------------------------------------- //
    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isTeacherOrAbove();
    }
    
    // ---------------------------------------------------- //
    // Auth Codes Collection
    // ---------------------------------------------------- //
    match /auth_codes/{codeId} {
      allow read: if isAuthenticated();
      // Only admins can create new codes or delete them
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isUsed', 'usedBy', 'useCount', 'usedAt']);
    }

    // ---------------------------------------------------- //
    // Help Requests Collection
    // ---------------------------------------------------- //
    match /help_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------- //
    // Error Reports Collection
    // ---------------------------------------------------- //
    match /error_reports/{reportId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------- //
    // Feedback Collection
    // ---------------------------------------------------- //
    match /feedback/{feedbackId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------- //
    // Alerts Collection
    // ---------------------------------------------------- //
    match /alerts/{alertId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------- //
    // Class Change Requests Collection
    // ---------------------------------------------------- //
    match /class_change_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------- //
    // User Sessions subcollection
    // ---------------------------------------------------- //
    match /users/{userId}/sessions/{sessionId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId);
      allow delete: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    // ---------------------------------------------------- //
    // School Info
    // ---------------------------------------------------- //
    match /school_info/{infoId} {
      allow read: if true;  // public — shown to guests too
      allow write: if isAdmin();
    }

    // ---------------------------------------------------- //
    // Default: deny everything else
    // ---------------------------------------------------- //
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
