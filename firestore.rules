rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ---------------------------------------------------- //
    // Helper Functions
    // ---------------------------------------------------- //
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'Official';
    }

    function isTeacherOrAbove() {
      return isAuthenticated() && (getUserRole() == 'Teacher' || getUserRole() == 'Official');
    }

    function isLeaderOrAbove() {
      return isAuthenticated() && (getUserRole() == 'Leader' || getUserRole() == 'Teacher' || getUserRole() == 'Official');
    }

    // ---------------------------------------------------- //
    // Users Collection
    // ---------------------------------------------------- //
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isOwner(userId);
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------- //
    // Messages / Forum Collection
    // ---------------------------------------------------- //
    match /messages/{messageId} {
      allow read, create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.senderId == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.senderId == request.auth.uid || isAdmin());
    }

    // ---------------------------------------------------- //
    // Forum Channels
    // ---------------------------------------------------- //
    match /forum_channels/{channelId} {
      allow read: if isAuthenticated();
      allow create: if isLeaderOrAbove();
      allow update: if isTeacherOrAbove();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------- //
    // Classes / Cohorts Collection
    // ---------------------------------------------------- //
    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow create, update: if isLeaderOrAbove();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------- //
    // Lessons Collection
    // ---------------------------------------------------- //
    match /lessons/{lessonId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isTeacherOrAbove();
    }

    // ---------------------------------------------------- //
    // Schedules Collection
    // ---------------------------------------------------- //
    match /schedules/{scheduleId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isTeacherOrAbove();
    }

    // ---------------------------------------------------- //
    // Notifications Collection
    // ---------------------------------------------------- //
    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isTeacherOrAbove();
    }
    
    // ---------------------------------------------------- //
    // Auth Codes Collection
    // ---------------------------------------------------- //
    match /auth_codes/{codeId} {
      // Allow unauthenticated read so verifyCode() works during registration
      allow read: if true;
      // Only admins can create new codes or delete them
      allow create: if isAdmin();
      allow delete: if isAdmin();
      // Allow anyone (including unauthenticated) to mark a code as used
      // Only the isUsed/usedBy fields may change — all other fields must stay
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isUsed', 'usedBy']);
    }

    // ---------------------------------------------------- //
    // Default: deny everything else
    // ---------------------------------------------------- //
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
